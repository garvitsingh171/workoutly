# Server runtime
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Local (non-Docker) MongoDB URI. Docker Compose overrides this to mongo:27017.
MONGO_URI=mongodb://127.0.0.1:27017/workoutly
MONGO_URI_TEST=mongodb://127.0.0.1:27017/workoutly_test
MONGODB_URI_TEST=mongodb://127.0.0.1:27017/workoutly_test

# Auth
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
